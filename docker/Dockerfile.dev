# ═══════════════════════════════════════════════════════════════════════
#  MindVault — Development Dockerfile
#  Includes test deps, hot-reload, mounts source as volume
#
#  Used by docker-compose.dev.yml
# ═══════════════════════════════════════════════════════════════════════
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ poppler-utils curl git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app

COPY requirements.txt .
RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir watchfiles pytest pytest-asyncio pytest-mock

EXPOSE 8000

# Source is bind-mounted; --reload watches for changes
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--log-level", "debug"]
