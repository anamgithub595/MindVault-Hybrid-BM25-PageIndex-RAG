# ═══════════════════════════════════════════════════════════════════════
#  MindVault — Environment Configuration
#  cp config/.env.example config/.env   then fill in your values
#  NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=MindVault
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info               # debug | info | warning | error
SECRET_KEY=change-me-to-a-long-random-string

# ── PageIndex (REQUIRED) ─────────────────────────────────────────────────
# Get your key from: https://dash.pageindex.ai/api-keys
PAGEINDEX_API_KEY=pi-your-key-here

# ── LLM Provider (pick ONE) ──────────────────────────────────────────────
LLM_PROVIDER=gemini          # anthropic | openai | gemini
ANTHROPIC_API_KEY=sk-ant-... # required if LLM_PROVIDER=anthropic
OPENAI_API_KEY=sk-...        # required if LLM_PROVIDER=openai
GEMINI_API_KEY=AIza...       # required if LLM_PROVIDER=gemini (free tier available)
LLM_MODEL=gemini-2.5-flash   # claude-sonnet-4-6 | gpt-4o | gemini-2.5-flash
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/mindvault.db

# ── BM25 tuning ──────────────────────────────────────────────────────────
BM25_K1=1.5
BM25_B=0.75
BM25_TOP_K=10                # candidates before hybrid fusion

# ── PageIndex retrieval ──────────────────────────────────────────────────
PI_TOP_K=5                   # nodes returned from PageIndex
PI_POLL_INTERVAL_SEC=2       # how often to poll retrieval status
PI_POLL_TIMEOUT_SEC=120      # max wait for retrieval task

# ── Hybrid fusion ────────────────────────────────────────────────────────
HYBRID_ALPHA=0.5             # 0.0 = pure BM25, 1.0 = pure PageIndex
FINAL_TOP_K=5                # final pages passed to LLM

# ── Ingestion ────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=50

# ── Optional connectors ──────────────────────────────────────────────────
NOTION_TOKEN=secret_...
NOTION_WORKSPACE_ID=
